{
  "name": "piz",
  "bin": {
    "piz": "./src/piz.ts",
    "unpiz": "./src/unpiz.ts"
  },
  "scripts": {
    "piz": "bun ./src/piz.ts",
    "unpiz": "bun ./src/unpiz.ts",
    "build": "bun build ./src/piz.ts --compile --outfile ./build/piz && bun build ./src/unpiz.ts --compile --outfile ./build/unpiz"
  },
  "type": "module",
  "module": "./src/index.ts",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "version": "0.0.1"
}
